{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "angle-game-spec.schema.json",
  "title": "AngleGameSpec",
  "type": "object",
  "required": [
    "title",
    "genre",
    "targetLabel",
    "coreLoop",
    "winCondition",
    "loseCondition",
    "orbitMode",
    "clarityConfig"
  ],
  "properties": {
    "title": { "type": "string" },
    "genre": {
      "type": "string",
      "const": "angle_identification"
    },
    "targetLabel": { "type": "string" },
    "synonyms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "normal", "hard"]
    },
    "platform": {
      "type": "string",
      "enum": ["desktop_web", "mobile_web", "both"]
    },
    "durationSeconds": { "type": "number", "minimum": 10 },
    "coreLoop": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "playerVerbs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["orbit", "zoom", "guess", "hint", "reset"]
      }
    },
    "orbitMode": {
      "type": "string",
      "enum": ["camera_orbit", "splat_rotate"]
    },
    "clarityConfig": {
      "type": "object",
      "required": ["winThreshold"],
      "properties": {
        "winThreshold": { "type": "number", "minimum": 0.5, "maximum": 1 },
        "hintBoost": { "type": "number", "minimum": 0, "maximum": 0.5 },
        "maxHints": { "type": "number", "minimum": 0 }
      }
    },
    "winCondition": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["correct_guess", "clarity_and_confirm", "either"]
        },
        "allowFuzzyMatch": { "type": "boolean" }
      }
    },
    "loseCondition": {
      "type": "object",
      "properties": {
        "timerSeconds": { "type": "number" },
        "maxWrongGuesses": { "type": "number", "minimum": 1 },
        "rotationBudgetDegrees": { "type": "number", "minimum": 0 }
      }
    },
    "guessMode": {
      "type": "string",
      "enum": ["text", "multiple_choice", "hybrid"]
    },
    "distractors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fallbackMode": {
      "type": "string",
      "enum": ["angle_orbit", "gradual_reveal"]
    },
    "acceptanceTests": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
