{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clarity-curve.schema.json",
  "title": "ClarityCurve",
  "type": "object",
  "required": ["samples", "peakAzimuthDeg", "peakWidthDeg", "sigmaRad"],
  "properties": {
    "sceneId": { "type": "string" },
    "truthAzimuthDeg": { "type": "number" },
    "truthElevationDeg": { "type": "number" },
    "peakAzimuthDeg": { "type": "number" },
    "peakWidthDeg": { "type": "number", "minimum": 5, "maximum": 90 },
    "sigmaRad": { "type": "number", "minimum": 0.01 },
    "floor": { "type": "number", "minimum": 0, "maximum": 0.5 },
    "ceiling": { "type": "number", "minimum": 0.5, "maximum": 1 },
    "symmetryRisk": { "type": "number", "minimum": 0, "maximum": 1 },
    "samples": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": ["azimuthDeg", "elevationDeg", "clarity"],
        "properties": {
          "azimuthDeg": { "type": "number" },
          "elevationDeg": { "type": "number" },
          "clarity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
