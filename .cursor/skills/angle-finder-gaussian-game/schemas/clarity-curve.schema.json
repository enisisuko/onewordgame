{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "clarity-curve.schema.json",
  "title": "ClarityCurve",
  "type": "object",
  "required": [
    "version",
    "difficulty",
    "sigmaRadians",
    "peak",
    "samples"
  ],
  "properties": {
    "version": { "type": "string" },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "normal", "hard"]
    },
    "sigmaRadians": {
      "type": "number",
      "minimum": 0.01
    },
    "peak": {
      "type": "object",
      "required": ["yawDegrees", "pitchDegrees", "clarity"],
      "properties": {
        "yawDegrees": { "type": "number" },
        "pitchDegrees": { "type": "number" },
        "clarity": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["yawDegrees", "pitchDegrees", "clarity"],
        "properties": {
          "yawDegrees": { "type": "number" },
          "pitchDegrees": { "type": "number" },
          "clarity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "canonicalSource": {
      "type": "string",
      "enum": ["api_metadata", "inferred_default", "manual_override"]
    }
  }
}
