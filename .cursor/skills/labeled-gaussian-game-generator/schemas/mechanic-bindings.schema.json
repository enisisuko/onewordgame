{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mechanic-bindings.schema.json",
  "type": "object",
  "required": [
    "bindings"
  ],
  "properties": {
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mechanicId",
          "objectId",
          "semanticLabel",
          "gameRole"
        ],
        "properties": {
          "mechanicId": {
            "type": "string"
          },
          "objectId": {
            "type": "string"
          },
          "semanticLabel": {
            "type": "string"
          },
          "gameRole": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          }
        }
      }
    }
  }
}
