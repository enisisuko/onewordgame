{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gaussian-metadata.schema.json",
  "title": "GaussianMetadata",
  "type": "object",
  "required": [
    "sceneId",
    "qualityTier",
    "centroid",
    "bounds"
  ],
  "properties": {
    "sceneId": { "type": "string" },
    "qualityTier": {
      "type": "string",
      "enum": ["fast_rough", "standard", "high"]
    },
    "sourceCamera": {
      "type": "object",
      "properties": {
        "position": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "target": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "fovDegrees": { "type": "number" }
      }
    },
    "centroid": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "bounds": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "max": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        }
      }
    },
    "canonicalYawDegrees": { "type": "number" },
    "canonicalPitchDegrees": { "type": "number" },
    "reconstructionConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "viewDependenceScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "assetUrls": {
      "type": "object",
      "properties": {
        "sog": { "type": "string" },
        "ply": { "type": "string" }
      }
    }
  }
}
